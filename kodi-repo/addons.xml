<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="repository.tvliveapp" name="TV Live App Repository" version="1.0.0" provider-name="TV Live App">

    <extension point="xbmc.addon.repository" name="TV Live App Repository">

        <dir>
            <info compressed="false">
                https://tvliveapp.github.io/kodi-repo/addons.xml
            </info>

            <checksum>
                https://tvliveapp.github.io/kodi-repo/addons.xml.md5
            </checksum>

            <datadir zip="true">
                https://tvliveapp.github.io/kodi-repo/
            </datadir>

            <hashes>sha256</hashes>
        </dir>

    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Repositorio oficial TV Live App</summary>
        <platform>all</platform>
    </extension>

</addon>
<addon id="service.m3userver" name="Servidor Web M3U" version="1.0.0" provider-name="IPTV Local">


<requires>
    <import addon="xbmc.python" version="3.0.0" />
     <import addon="script.module.requests" version="2.31.0" />

    <import addon="script.module.beautifulsoup4" version="4.12.0" />
</requires>



<extension point="xbmc.service" library="main.py" start="startup" />



<extension point="xbmc.python.pluginsource" library="default.py">


    <provides>video</provides>


</extension>


<extension point="xbmc.addon.metadata">

    <summary>
    Servidor HTTP M3U
    </summary>

    <platform>all</platform>

</extension>


</addon>
</addons>
