    <extension point="xbmc.addon.repository"
               name="IPTV Local">
        <dir>
            <info compressed="false">
                https://juan123.github.io/repo-kodi/addons.xml
            </info>
            <checksum>
                https://juan123.github.io/repo-kodi/addons.xml.md5
            </checksum>
            <datadir zip="true">
